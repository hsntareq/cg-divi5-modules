{
  "name": "cg/carousel-item",
  "d4Shortcode": "",
  "title": "Carousel Item",
  "titles": "Carousel Items",
  "moduleIcon": "cg/module-carousel-item",
  "moduleClassName": "cg_carousel_item",
  "moduleOrderClassName": "cg_carousel_item",
  "category": "child-module",
  "parentName": [
    "cg/carousel"
  ],
  "mousetrap": {
    "inner": {
      "edited": true
    }
  },
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": "Carousel Item"
            }
          }
        }
      },
      "styleProps": {
        "border": {
          "important": true
        }
      },
      "settings": {
        "advanced": {
          "link": {},
          "text": {
            "component": {
              "props": {
                "fields": {
                  "color": {
                    "render": false
                  }
                }
              }
            }
          },
          "htmlAttributes": {}
        },
        "decoration": {
          "background": {},
          "sizing": {},
          "spacing": {},
          "border": {},
          "boxShadow": {},
          "filters": {},
          "transform": {},
          "animation": {},
          "overflow": {},
          "disabledOn": {},
          "transition": {},
          "position": {},
          "zIndex": {},
          "scroll": {},
          "sticky": {}
        }
      }
    },
    "image": {
      "type": "object",
      "selector": "{{selector}} .cg_carousel_item__image img",
      "elementType": "imageLink",
      "supportsCustomAttributes": true,
      "styleProps": {
        "border": {
          "important": true
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-items",
          "items": {
            "src": {
              "groupSlug": "slideContent",
              "attrName": "image.innerContent",
              "subName": "src",
              "priority": 10,
              "render": true,
              "label": "Slide Image",
              "description": "Upload an image for this slide.",
              "features": {
                "sticky": false,
                "dynamicContent": false
              },
              "component": {
                "name": "divi/upload",
                "type": "field",
                "props": {
                  "syncImageData": {
                    "src": true,
                    "id": true,
                    "alt": true,
                    "titleText": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "title": {
      "type": "object",
      "selector": "{{selector}} .cg_carousel_item__title",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "slideContent",
            "priority": 20,
            "render": true,
            "attrName": "title.innerContent",
            "label": "Slide Title",
            "description": "Enter the slide title.",
            "features": {
              "sticky": false,
              "dynamicContent": false
            },
            "component": {
              "name": "divi/text",
              "type": "field"
            }
          }
        },
        "decoration": {
          "font": {
            "priority": 10,
            "component": {
              "props": {
                "groupLabel": "Title Text",
                "fieldLabel": "Title"
              }
            }
          }
        }
      },
      "tagName": "h3",
      "attributes": {
        "class": "cg_carousel_item__title"
      },
      "inlineEditor": "plainText",
      "elementType": "heading",
      "childrenSanitizer": "et_core_esc_previously"
    }
  },
  "customCssFields": {},
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "slideContent": {
        "panel": "content",
        "priority": 10,
        "groupName": "mainContent",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Slide Content"
          }
        }
      }
    }
  }
}
