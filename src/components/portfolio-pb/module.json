{
  "name": "cg/portfolio-pb",
  "d4Shortcode": "",
  "title": "Portfolio PB",
  "titles": "Portfolio PBs",
  "moduleIcon": "cg/module-static",
  "moduleClassName": "cg_portfolio_pb",
  "moduleOrderClassName": "cg_portfolio_pb",
  "category": "module",
  "mousetrap": {
    "inner": {
      "edited": true
    }
  },
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": "Portfolio PB"
            }
          }
        }
      },
      "styleProps": {
        "border": {
          "important": true
        }
      },
      "settings": {
        "meta": {
          "adminLabel": {}
        },
        "advanced": {
          "link": {},
          "text": {},
          "htmlAttributes": {}
        },
        "decoration": {
          "background": {},
          "sizing": {},
          "spacing": {},
          "border": {},
          "boxShadow": {},
          "filters": {},
          "transform": {},
          "animation": {},
          "overflow": {},
          "disabledOn": {},
          "transition": {},
          "position": {},
          "zIndex": {},
          "scroll": {},
          "sticky": {}
        }
      }
    },
    "postType": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "post"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "portfolioSettingsGroup",
            "attrName": "postType.innerContent",
            "priority": 10,
            "render": true,
            "label": "Post Type",
            "component": {
              "name": "divi/select",
              "type": "field",
              "props": {
                "options": {
                  "post": {
                    "label": "Posts"
                  },
                  "project": {
                    "label": "Projects"
                  }
                }
              }
            }
          }
        }
      }
    },
    "postsNumber": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "12"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "portfolioSettingsGroup",
            "attrName": "postsNumber.innerContent",
            "priority": 20,
            "render": true,
            "label": "Posts Number",
            "description": "Select the number of posts to display in the grid.",
            "component": {
              "name": "divi/range",
              "type": "field",
              "props": {
                "min": 1,
                "max": 100,
                "step": 1,
                "allowedUnits": [],
                "defaultUnit": ""
              }
            }
          }
        }
      }
    },
    "gridColumns": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "3"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "portfolioSettingsGroup",
            "attrName": "gridColumns.innerContent",
            "priority": 30,
            "render": true,
            "label": "Grid Columns",
            "component": {
              "name": "divi/select",
              "type": "field",
              "props": {
                "options": {
                  "2": {
                    "label": "2 Columns"
                  },
                  "3": {
                    "label": "3 Columns"
                  },
                  "4": {
                    "label": "4 Columns"
                  }
                }
              }
            }
          }
        }
      }
    },
    "hideEmptySubcats": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "portfolioSettingsGroup",
            "attrName": "hideEmptySubcats.innerContent",
            "priority": 40,
            "render": true,
            "label": "Hide Empty Sub-categories",
            "description": "Hide subcategories that have no items in the current query.",
            "component": {
              "name": "divi/toggle",
              "type": "field"
            }
          }
        }
      }
    },
    "directSubcatLabel": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "parent"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "portfolioSettingsGroup",
            "attrName": "directSubcatLabel.innerContent",
            "priority": 50,
            "render": true,
            "label": "Direct Sub-category Label",
            "description": "Choose the label style for the subcategory filtering items directly in the parent category.",
            "component": {
              "name": "divi/select",
              "type": "field",
              "props": {
                "options": {
                  "parent": {
                    "label": "Parent Category Name (e.g. Watch)"
                  },
                  "direct": {
                    "label": "Direct"
                  },
                  "other": {
                    "label": "Other"
                  }
                }
              }
            }
          }
        }
      }
    },
    "showLoadMore": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "portfolioSettingsGroup",
            "attrName": "showLoadMore.innerContent",
            "priority": 60,
            "render": true,
            "label": "Show Load More Button",
            "description": "Show a button to load more items when they exceed the limit.",
            "component": {
              "name": "divi/toggle",
              "type": "field"
            }
          }
        }
      }
    },
    "loadMoreText": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "Load More"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "portfolioSettingsGroup",
            "attrName": "loadMoreText.innerContent",
            "priority": 70,
            "render": true,
            "label": "Load More Button Text",
            "description": "Customize the text of the Load More button.",
            "component": {
              "name": "divi/text",
              "type": "field"
            }
          }
        }
      }
    },
    "openInNewTab": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "portfolioSettingsGroup",
            "attrName": "openInNewTab.innerContent",
            "priority": 80,
            "render": true,
            "label": "Open Links in New Tab",
            "description": "Open external and custom post links in a new tab.",
            "component": {
              "name": "divi/toggle",
              "type": "field"
            }
          }
        }
      }
    },
    "activeColor": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "#7e22ce"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "portfolioStylesGroup",
            "attrName": "activeColor.innerContent",
            "priority": 10,
            "render": true,
            "label": "Active Theme Color",
            "description": "Select the primary accent color for active tabs and filter pills.",
            "component": {
              "name": "divi/color-picker",
              "type": "field"
            }
          }
        }
      }
    },
    "titleText": {
      "type": "object",
      "selector": "{{selector}} .cg_portfolio_pb__card-title",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "decoration": {
          "font": {
            "priority": 10,
            "component": {
              "props": {
                "groupLabel": "Title Text",
                "fieldLabel": "Title",
                "fields": {
                  "headingLevel": {
                    "render": false
                  }
                }
              }
            }
          }
        }
      }
    },
    "tabText": {
      "type": "object",
      "selector": "{{selector}} .cg_portfolio_pb__tab",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "decoration": {
          "font": {
            "priority": 20,
            "component": {
              "props": {
                "groupLabel": "Filter Tabs Text",
                "fieldLabel": "Tab"
              }
            }
          }
        }
      }
    },
    "radioPillText": {
      "type": "object",
      "selector": "{{selector}} .cg_portfolio_pb__radio-pill span",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "decoration": {
          "font": {
            "priority": 30,
            "component": {
              "props": {
                "groupLabel": "Subcategory Tabs Text",
                "fieldLabel": "Subcategory Pill"
              }
            }
          }
        }
      }
    },
    "loadMoreBtn": {
      "type": "object",
      "selector": "{{selector}} .cg_portfolio_pb__load-more-btn",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true
                }
              }
            }
          }
        }
      },
      "settings": {
        "decoration": {
          "font": {
            "priority": 40,
            "component": {
              "props": {
                "groupLabel": "Load More Button Text",
                "fieldLabel": "Button"
              }
            }
          }
        }
      }
    },
    "item": {
      "type": "object",
      "selector": "{{selector}} .cg_portfolio_pb__card",
      "styleProps": {
        "border": {
          "important": true
        }
      },
      "settings": {
        "decoration": {
          "border": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "portfolioItemStylesGroup",
              "priority": 10,
              "render": true,
              "component": {
                "type": "group",
                "name": "divi/border",
                "props": {
                  "grouped": false
                }
              }
            }
          }
        }
      }
    }
  },
  "customCssFields": {},
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "portfolioSettingsGroup": {
        "panel": "content",
        "priority": 10,
        "groupName": "mainContent",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Portfolio Settings"
          }
        }
      },
      "portfolioStylesGroup": {
        "panel": "design",
        "priority": 10,
        "groupName": "portfolioStylesGroup",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Portfolio Accent Styling"
          }
        }
      },
      "portfolioItemStylesGroup": {
        "panel": "design",
        "priority": 15,
        "groupName": "portfolioItemStylesGroup",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Portfolio Item Style"
          }
        }
      }
    }
  }
}
