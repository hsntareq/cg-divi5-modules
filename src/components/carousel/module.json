{
  "name": "cg/carousel",
  "d4Shortcode": "",
  "title": "Carousel",
  "titles": "Carousels",
  "moduleIcon": "cg/module-carousel",
  "moduleClassName": "cg_carousel",
  "moduleOrderClassName": "cg_carousel",
  "category": "module",
  "childModuleName": "cg/carousel-item",
  "childModuleTitle": "Carousel Item",
  "childrenName": [
    "cg/carousel-item"
  ],
  "mousetrap": {
    "inner": {
      "edited": true
    }
  },
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": "Carousel"
            }
          }
        }
      },
      "styleProps": {
        "border": {
          "important": true
        }
      },
      "settings": {
        "meta": {
          "adminLabel": {}
        },
        "advanced": {
          "link": {},
          "text": {
            "component": {
              "props": {
                "fields": {
                  "color": {
                    "render": false
                  }
                }
              }
            }
          },
          "htmlAttributes": {}
        },
        "decoration": {
          "background": {},
          "sizing": {},
          "spacing": {},
          "border": {},
          "boxShadow": {},
          "filters": {},
          "transform": {},
          "animation": {},
          "overflow": {},
          "disabledOn": {},
          "transition": {},
          "position": {},
          "zIndex": {},
          "scroll": {},
          "sticky": {}
        }
      }
    },
    "autoplay": {
      "type": "string",
      "default": {
        "desktop": {
          "value": "off"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "sliderSettingsGroup",
            "attrName": "autoplay",
            "priority": 10,
            "render": true,
            "label": "Autoplay",
            "component": {
              "name": "divi/toggle",
              "type": "field"
            }
          }
        }
      }
    },
    "speed": {
      "type": "string",
      "default": {
        "desktop": {
          "value": "3000"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "sliderSettingsGroup",
            "attrName": "speed",
            "priority": 20,
            "render": true,
            "label": "Autoplay Speed (ms)",
            "component": {
              "name": "divi/range",
              "type": "field",
              "props": {
                "min": 500,
                "max": 10000,
                "step": 100,
                "allowedUnits": ["ms"]
              }
            }
          }
        }
      }
    },
    "transitionSpeed": {
      "type": "string",
      "default": {
        "desktop": {
          "value": "500"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "sliderSettingsGroup",
            "attrName": "transitionSpeed",
            "priority": 30,
            "render": true,
            "label": "Transition Duration (ms)",
            "component": {
              "name": "divi/range",
              "type": "field",
              "props": {
                "min": 100,
                "max": 3000,
                "step": 50,
                "allowedUnits": ["ms"]
              }
            }
          }
        }
      }
    },
    "loop": {
      "type": "string",
      "default": {
        "desktop": {
          "value": "on"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "sliderSettingsGroup",
            "attrName": "loop",
            "priority": 40,
            "render": true,
            "label": "Infinite Loop",
            "component": {
              "name": "divi/toggle",
              "type": "field"
            }
          }
        }
      }
    },
    "arrows": {
      "type": "string",
      "default": {
        "desktop": {
          "value": "on"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "sliderSettingsGroup",
            "attrName": "arrows",
            "priority": 50,
            "render": true,
            "label": "Show Navigation Arrows",
            "component": {
              "name": "divi/toggle",
              "type": "field"
            }
          }
        }
      }
    },
    "dots": {
      "type": "string",
      "default": {
        "desktop": {
          "value": "on"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "sliderSettingsGroup",
            "attrName": "dots",
            "priority": 60,
            "render": true,
            "label": "Show Pagination Dots",
            "component": {
              "name": "divi/toggle",
              "type": "field"
            }
          }
        }
      }
    },
    "slidesToShow": {
      "type": "string",
      "default": {
        "desktop": {
          "value": "4"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "sliderSettingsGroup",
            "attrName": "slidesToShow",
            "priority": 70,
            "render": true,
            "label": "Slides To Show",
            "component": {
              "name": "divi/range",
              "type": "field",
              "props": {
                "min": 1,
                "max": 8,
                "step": 1,
                "allowedUnits": []
              }
            }
          }
        }
      }
    }
  },
  "customCssFields": {},
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "sliderSettingsGroup": {
        "panel": "content",
        "priority": 10,
        "groupName": "mainContent",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Slider Settings"
          }
        }
      }
    }
  }
}
