    "showTitle": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "elementsSettingsGroup",
            "attrName": "showTitle.innerContent",
