  "category": "module",
  "childModuleName": "cg/carousel-item",
  "childModuleTitle": "Carousel Item",
  "childrenName": [
    "cg/carousel-item"
  ],
  "mousetrap": {
    "inner": {
      "edited": true
    }
  },
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": "Carousel"
            }
          }
        }
      },
      "styleProps": {
        "border": {
          "important": true
        }
      },
      "settings": {
        "meta": {
          "adminLabel": {}
        },
        "advanced": {
          "link": {},
          "text": {
            "component": {
              "props": {
                "fields": {
                  "color": {
                    "render": false
                  }
                }
              }
            }
          },
          "htmlAttributes": {}
        },
        "decoration": {
          "background": {},
          "sizing": {},
          "spacing": {},
          "border": {},
          "boxShadow": {},
          "filters": {},
          "transform": {},
          "animation": {},
          "overflow": {},
          "disabledOn": {},
          "transition": {},
          "position": {},
          "zIndex": {},
          "scroll": {},
          "sticky": {}
        }
      }
    },
    "autoplay": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "sliderSettingsGroup",
            "attrName": "autoplay.innerContent",
            "priority": 10,
            "render": true,
            "label": "Autoplay",
            "component": {
              "name": "divi/toggle",
              "type": "field"
            }
          }
        }
      }
    },
    "speed": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "3000"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "sliderSettingsGroup",
            "attrName": "speed.innerContent",
            "priority": 20,
            "render": true,
            "label": "Autoplay Speed (ms)",
            "component": {
              "name": "divi/range",
              "type": "field",
              "props": {
                "min": 500,
                "max": 10000,
                "step": 100,
                "allowedUnits": [],
                "defaultUnit": ""
              }
            }
          }
        }
      }
    },
    "transitionSpeed": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "500"
